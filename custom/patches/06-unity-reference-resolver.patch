+      const marker = node.qualifiedName.lastIndexOf('::');
+      if (marker < 0) continue;
+      const fileId = Number(node.qualifiedName.slice(marker + 2));
+      if (!Number.isFinite(fileId)) continue;
+      let anchors = localAnchorsByFile.get(node.filePath);
+      if (!anchors) {
+        anchors = new Map<number, string>();
+        localAnchorsByFile.set(node.filePath, anchors);
+      }
+      anchors.set(fileId, node.id);
+    }
+
+    const { resolved, placeholderNodes } = resolveUnityEdges(
+      this.unityRawEdges,
+      guidToNodeId,
+      localAnchorsByFile
+    );
+    if (placeholderNodes.length > 0) this.queries.insertNodes(placeholderNodes);
+    if (resolved.length > 0) this.queries.insertEdges(resolved);
+    return resolved.length;
+  }
