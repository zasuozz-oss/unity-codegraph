+  private async handleUnityFindMissingScripts(args: Record<string, unknown>): Promise<ToolResult> {
+    const cg = this.getCodeGraph(args.projectPath as string | undefined);
+    const edges = cg.getEdgesByRelation('missing_script');
+    if (edges.length === 0) {
+      return this.textResult('No missing Unity scripts found.');
+    }
+
+    const seen = new Set<string>();
+    const lines = [`## Missing Unity Scripts (${edges.length} edge${edges.length === 1 ? '' : 's'})`, ''];
+    for (const edge of edges) {
+      const source = cg.getNode(edge.source);
+      const metadata = (edge.metadata ?? {}) as Record<string, unknown>;
+      const filePath = source?.filePath ?? String(metadata.filePath ?? edge.source);
+      const guid = typeof metadata.guid === 'string' ? ` guid=${metadata.guid}` : '';
+      const key = `${filePath}:${guid}`;
+      if (seen.has(key)) continue;
+      seen.add(key);
+      lines.push(`- ${filePath}${guid}`);
+    }
+
+    return this.textResult(this.truncateOutput(lines.join('\n')));
+  }
+
+  private async handleUnityFindReferencesToAsset(args: Record<string, unknown>): Promise<ToolResult> {
+    const asset = this.validateString(args.asset, 'asset');
+    if (typeof asset !== 'string') return asset;
+
+    const cg = this.getCodeGraph(args.projectPath as string | undefined);
+    const normalized = asset.replace(/\\/g, '/');
+    const candidates = cg.searchNodes(asset, { limit: 50 })
+      .map((result) => result.node)
+      .filter((node) =>
+        (node.kind === 'unity_asset' || node.kind === 'unity_prefab' || node.kind === 'unity_scene') &&
+        (node.filePath === normalized || node.filePath.endsWith(`/${normalized}`) || node.name === asset)
+      );
+
+    if (candidates.length === 0) {
+      return this.textResult(`Unity asset "${asset}" not found.`);
+    }
+
+    const referenceRelations = new Set([
+      'serialized_field_references_asset',
+      'scene_references_prefab',
+      'addressable_references_asset',
+    ]);
+    const lines = [`## Unity References to ${asset}`, ''];
+    const seen = new Set<string>();
+
+    for (const target of candidates) {
+      for (const edge of cg.getIncomingEdges(target.id)) {
+        const relation = (edge.metadata as any)?.unityRelation;
+        if (!referenceRelations.has(relation)) continue;
+        const source = cg.getNode(edge.source);
+        if (!source) continue;
+        const field = typeof (edge.metadata as any)?.fieldName === 'string'
+          ? ` field=${(edge.metadata as any).fieldName}`
+          : '';
+        const key = `${source.filePath}:${relation}:${field}`;
+        if (seen.has(key)) continue;
+        seen.add(key);
+        lines.push(`- ${source.filePath} (${relation}${field})`);
+      }
+    }
+
+    if (seen.size === 0) {
+      return this.textResult(`No Unity references found for "${asset}".`);
+    }
+    return this.textResult(this.truncateOutput(lines.join('\n')));
+  }
