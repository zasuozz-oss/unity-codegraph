+/**
+ * codegraph unity <command> [args...]
+ *
+ * Thin Unity-mode wrapper. It re-dispatches into the normal command tree after
+ * enabling Unity mode for this process. Passing --assets enables full-asset
+ * extraction and strips that flag before the upstream command parser sees it.
+ */
+program
+  .command('unity [command...]')
+  .description('Run any codegraph command with Unity extraction enabled (add --assets for prefab/scene/asset graph)')
+  .allowUnknownOption(true)
+  .allowExcessArguments(true)
+  .helpOption(false)
+  .action(async (commandArgs: string[]) => {
+    const unityIdx = process.argv.indexOf('unity');
+    const forwarded = unityIdx >= 0 ? process.argv.slice(unityIdx + 1) : (commandArgs || []);
+    const wantAssets = forwarded.includes('--assets');
+    const strippedForwarded = forwarded.filter((a) => a !== '--assets');
+
+    if (wantAssets) {
+      enableUnityAssetMode();
+    } else {
+      enableUnityMode();
+    }
+
+    if (strippedForwarded.length === 0) {
+      program.outputHelp();
+      return;
+    }
+
+    const sub = strippedForwarded[0];
+    if (sub === 'init' || sub === 'index' || sub === 'sync') {
+      const pathArg = strippedForwarded.slice(1).find((a) => !a.startsWith('-'));
+      const projectPath = path.resolve(pathArg || process.cwd());
+      process.once('exit', () => {
+        if (!isInitialized(projectPath)) return;
+        if (wantAssets) writeUnityAssetMarker(projectPath);
+        else writeUnityMarker(projectPath);
+        try {
+          upsertProject(projectPath);
+        } catch { /* non-fatal */ }
+      });
+    }
+
+    await program.parseAsync(['node', 'codegraph', ...strippedForwarded]);
+  });
+
