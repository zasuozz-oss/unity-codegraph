+  private extractDecoratorNames(node: SyntaxNode): string[] {
+    const names = new Set<string>();
+    const decoratorTypes = new Set([
+      'decorator',
+      'annotation',
+      'marker_annotation',
+      'attribute',
+      'attribute_list',
+    ]);
+
+    for (let i = 0; i < node.namedChildCount; i++) {
+      const child = node.namedChild(i);
+      if (!child || !decoratorTypes.has(child.type)) continue;
+      const text = getNodeText(child, this.source);
+      const regex = /(?:^|[\[\s,@])([A-Za-z_][\w.]*)(?=\s*(?:\(|\]|,|$))/g;
+      let match: RegExpExecArray | null;
+      while ((match = regex.exec(text)) !== null) {
+        const rawName = match[1];
+        if (!rawName || rawName === 'typeof') continue;
+        names.add(rawName.split('.').pop() ?? rawName);
+      }
+    }
+
+    return [...names];
+  }
