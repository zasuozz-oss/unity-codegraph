+function isUnityImportedAssetPath(filePath: string): boolean {
+  return UNITY_IMPORTED_NODE_EXTENSIONS.has(path.extname(filePath).toLowerCase());
+}
+
+async function readIndexContent(fullPath: string, relativePath: string): Promise<{
+  content: string;
+  stats: fs.Stats;
+}> {
+  const stats = await fsp.stat(fullPath);
+  const hasMetaSidecar = fs.existsSync(`${fullPath}.meta`);
+  if (
+    !isUnityImportedAssetPath(relativePath) &&
+    !(hasMetaSidecar && detectLanguage(relativePath) === 'unknown')
+  ) {
+    return { content: await fsp.readFile(fullPath, 'utf-8'), stats };
+  }
+
+  let metaContent = '';
+  try {
+    metaContent = await fsp.readFile(`${fullPath}.meta`, 'utf-8');
+  } catch {
+    // Imported assets without a sidecar still get a stable file-level node.
+  }
+  return {
+    content: `unity-imported:${stats.size}:${Math.floor(stats.mtimeMs)}:${hashContent(metaContent)}`,
+    stats,
+  };
+}
