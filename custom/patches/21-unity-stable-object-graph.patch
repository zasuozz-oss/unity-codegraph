+function stabilizeUnityExtractionResult(
+  result: UnityAssetExtractionResult,
+  assetGuid: string
+): UnityAssetExtractionResult {
+  const remappedIds = new Map<string, string>();
+  const nodes = result.nodes.map((node) => {
+    const marker = node.qualifiedName.lastIndexOf('::');
+    if (marker < 0) return node;
+    const localFileId = node.qualifiedName.slice(marker + 2);
+    const id = generateUnityNodeId(assetGuid, node.kind, localFileId);
+    remappedIds.set(node.id, id);
+    return { ...node, id };
+  });
+  const remap = (id: string | undefined): string | undefined =>
+    id ? remappedIds.get(id) ?? id : undefined;
+
+  return {
+    ...result,
+    nodes,
+    edges: result.edges.map((edge) => ({
+      ...edge,
+      source: remap(edge.source)!,
+      target: remap(edge.target)!,
+    })),
+    unityRawEdges: result.unityRawEdges.map((edge) => ({
+      ...edge,
+      source: remap(edge.source),
+      target: remap(edge.target),
+    })),
+  };
